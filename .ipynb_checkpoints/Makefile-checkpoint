.DEFAULT_GOAL := all

CC = x86_64-w64-mingw32-gcc
AR = x86_64-w64-mingw32-ar

SRC_DIR := src
INCLUDE_DIR := include
WIN_GUI_DIR := win_gui
BUILD_DIR ?= build
THIRD_PARTY_DIR := third_party
BIN_DIR ?= bin
DLL_DIR ?= dll
LIB_DIR ?= lib

MINGW_INCLUDE_DIR := $(THIRD_PARTY_DIR)/mingw/include
THIRD_PARTY_LIB_DIR := $(THIRD_PARTY_DIR)/lib
PML_SOURCE_DIR := $(THIRD_PARTY_DIR)/pml
PML_INCLUDE_DIR := $(PML_SOURCE_DIR)/src
PML_OBJ_DIR := $(BUILD_DIR)/third_party/pml/obj

DRSOLVE_TARGET ?= drsolve.exe
DRSOLVE_REAL_TARGET ?= $(BIN_DIR)/drsolve_cli_real.exe
DRSOLVE_STATIC_LIB ?= $(LIB_DIR)/libdrsolve-1.a
DRSOLVE_DLL ?= $(DLL_DIR)/libdrsolve-1.dll
DRSOLVE_DLL_IMPORT ?= $(LIB_DIR)/libdrsolve-1.dll.a
PML_DLL ?= $(DLL_DIR)/libpml.dll
PML_DLL_IMPORT ?= $(LIB_DIR)/libpml.dll.a
WIN_GUI_TARGET ?= drsolve_win_gui.exe
LAUNCHER_SOURCE := $(WIN_GUI_DIR)/dixon_launcher.c

COMMON_CFLAGS ?= -O2 -fopenmp -msse4.1 -mpclmul
GUI_CFLAGS ?= -O2 -D_WIN32_WINNT=0x0601
CPPFLAGS += -DHAVE_FLINT -DHAVE_PML -DHAVE_WINDOWS_H=1 -DPML_HAVE_MACHINE_VECTORS=0
PML_CPPFLAGS += -DSTDC_HEADERS=1 -DFLINT_UNROLL_LOOPS=1 -DPML_USES_PTHREAD=1 -DPML_USES_TLS=1 -DPML_WANT_GMP_INTERNALS=1 -DPML_WANT_PRETTY_TESTS=1
INCLUDE_FLAGS := -I$(INCLUDE_DIR) -I$(PML_INCLUDE_DIR) -I$(MINGW_INCLUDE_DIR)
CLI_LIB_DIRS := -L$(LIB_DIR) -L$(THIRD_PARTY_LIB_DIR)
CLI_LIBS := -lpml -lflint -lmpfr -lgmp -lopenblas -lm -lpthread
GUI_LIBS := -lcomctl32 -lcomdlg32 -lshlwapi -lwinmm

MATH_SOURCES = $(SRC_DIR)/dixon_complexity.c \
               $(SRC_DIR)/dixon_flint.c \
               $(SRC_DIR)/dixon_interface_flint.c \
               $(SRC_DIR)/dixon_test.c \
               $(SRC_DIR)/dixon_with_ideal_reduction.c \
               $(SRC_DIR)/fq_mat_det.c \
               $(SRC_DIR)/fq_mpoly_mat_det.c \
               $(SRC_DIR)/fq_multivariate_interpolation.c \
               $(SRC_DIR)/fq_mvpoly.c \
               $(SRC_DIR)/fq_nmod_roots.c \
               $(SRC_DIR)/fq_poly_mat_det.c \
               $(SRC_DIR)/fq_sparse_interpolation.c \
               $(SRC_DIR)/fq_unified_interface.c \
               $(SRC_DIR)/gf2n_mpoly.c \
               $(SRC_DIR)/gf2n_field.c \
               $(SRC_DIR)/gf2n_poly.c \
               $(SRC_DIR)/polynomial_system_solver.c \
               $(SRC_DIR)/resultant_with_ideal_reduction.c \
               $(SRC_DIR)/unified_mpoly_det.c \
               $(SRC_DIR)/unified_mpoly_interface.c \
               $(SRC_DIR)/unified_mpoly_resultant.c \
               $(SRC_DIR)/rational_system_solver.c \
               $(SRC_DIR)/fmpq_acb_roots.c

MATH_OBJECTS := $(patsubst $(SRC_DIR)/%.c,$(BUILD_DIR)/drsolve/%.o,$(MATH_SOURCES))
PML_SOURCES := $(shell find $(PML_SOURCE_DIR)/src \
	\( -path '*/test/*' -o -path '*/profile/*' -o -path '*/timings/*' -o -path '*/tune/*' -o -path '*/mapml/*' -o -path '*/.ipynb_checkpoints/*' \) -prune -o \
	-name '*.c' -print)
PML_OBJECTS := $(patsubst $(PML_SOURCE_DIR)/src/%.c,$(PML_OBJ_DIR)/%.o,$(PML_SOURCES))
WIN_GUI_SOURCES := $(WIN_GUI_DIR)/dixon_gui.c

.PHONY: all clean show-config package-layout

all: $(DRSOLVE_TARGET) $(DRSOLVE_REAL_TARGET) $(WIN_GUI_TARGET) $(DRSOLVE_DLL) $(PML_DLL)

$(BUILD_DIR) $(BIN_DIR) $(DLL_DIR) $(LIB_DIR):
	mkdir -p $@

$(BUILD_DIR)/drsolve/%.o: $(SRC_DIR)/%.c | $(BUILD_DIR)
	@mkdir -p $(dir $@)
	$(CC) $(COMMON_CFLAGS) $(CPPFLAGS) $(INCLUDE_FLAGS) -c -o $@ $<

$(PML_OBJ_DIR)/%.o: $(PML_SOURCE_DIR)/src/%.c | $(BUILD_DIR)
	@mkdir -p $(dir $@)
	$(CC) $(COMMON_CFLAGS) $(CPPFLAGS) $(PML_CPPFLAGS) -I$(PML_INCLUDE_DIR) -I$(MINGW_INCLUDE_DIR) -c -o $@ $<

$(PML_DLL): $(PML_OBJECTS) | $(DLL_DIR) $(LIB_DIR)
	$(CC) -shared -Wl,--out-implib,$(PML_DLL_IMPORT) -o $@ $^ -L$(THIRD_PARTY_LIB_DIR) -lflint -lmpfr -lgmp -lopenblas -lm -lpthread -fopenmp

$(PML_DLL_IMPORT): $(PML_DLL)

$(DRSOLVE_STATIC_LIB): $(MATH_OBJECTS) | $(LIB_DIR)
	$(AR) rcs $@ $^

$(DRSOLVE_DLL): $(MATH_OBJECTS) $(PML_DLL_IMPORT) | $(DLL_DIR) $(LIB_DIR)
	$(CC) -shared -Wl,--out-implib,$(DRSOLVE_DLL_IMPORT) -o $@ $(MATH_OBJECTS) $(CLI_LIB_DIRS) $(CLI_LIBS) -fopenmp

$(DRSOLVE_TARGET): $(LAUNCHER_SOURCE)
	$(CC) $(GUI_CFLAGS) -o $@ $<

$(DRSOLVE_REAL_TARGET): drsolve.c $(DRSOLVE_STATIC_LIB) $(PML_DLL_IMPORT) | $(BIN_DIR)
	$(CC) $(COMMON_CFLAGS) $(CPPFLAGS) $(INCLUDE_FLAGS) -o $@ $< $(DRSOLVE_STATIC_LIB) $(CLI_LIB_DIRS) $(CLI_LIBS) -fopenmp

$(WIN_GUI_TARGET): $(WIN_GUI_SOURCES)
	$(CC) $(GUI_CFLAGS) -mwindows -o $@ $(WIN_GUI_SOURCES) $(GUI_LIBS)

package-layout:
	@echo "root executables: $(DRSOLVE_TARGET) $(WIN_GUI_TARGET)"
	@echo "internal cli     : $(DRSOLVE_REAL_TARGET)"
	@echo "dlls             : $(PML_DLL) $(DRSOLVE_DLL)"
	@echo "runtime dir       : $(DLL_DIR)/"
	@echo "import libraries : $(PML_DLL_IMPORT) $(DRSOLVE_DLL_IMPORT)"
	@echo "static libraries : $(DRSOLVE_STATIC_LIB)"

show-config:
	@echo "CC                  = $(CC)"
	@echo "MINGW_INCLUDE_DIR   = $(MINGW_INCLUDE_DIR)"
	@echo "THIRD_PARTY_LIB_DIR = $(THIRD_PARTY_LIB_DIR)"
	@echo "PML_SOURCE_DIR      = $(PML_SOURCE_DIR)"
	@echo "PML_INCLUDE_DIR     = $(PML_INCLUDE_DIR)"
	@echo "DRSOLVE_TARGET      = $(DRSOLVE_TARGET)"
	@echo "DRSOLVE_REAL_TARGET = $(DRSOLVE_REAL_TARGET)"
	@echo "WIN_GUI_TARGET      = $(WIN_GUI_TARGET)"
	@echo "PML_DLL             = $(PML_DLL)"
	@echo "DRSOLVE_DLL         = $(DRSOLVE_DLL)"
	@echo "DLL_DIR             = $(DLL_DIR)"
	@echo "LIB_DIR             = $(LIB_DIR)"

clean:
	rm -rf $(BUILD_DIR) $(BIN_DIR) $(DLL_DIR) $(LIB_DIR)
	rm -f $(DRSOLVE_TARGET) $(WIN_GUI_TARGET) $(DRSOLVE_REAL_TARGET)
	rm -f dixon.exe dixon_win_gui.exe dixon_cli_real.exe
	rm -f libdrsolve-1.a libdrsolve-1.dll libdrsolve-1.dll.a libpml.dll libpml.dll.a
	rm -f libdixon-1.a libdixon-1.dll libdixon-1.dll.a libpml.a
